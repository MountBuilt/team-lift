rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Trusted small group; obscurity-level security accepted per spec §3.
    match /users/{userId} { allow read, write: if true; }
    match /entries/{entryId} { allow read, write: if true; }
    match /config/{docId} { allow read, write: if true; }
  }
}
